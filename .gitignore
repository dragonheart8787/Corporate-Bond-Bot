# Telegram session 檔（含登入憑證，絕對不可上傳）
*.session
*.session-journal

# 本機設定（含敏感憑證，不可上傳）
configs/telegram_api.json
configs/telegram_bot_config.json

# Python 暫存
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/

# 輸出資料（可選擇不上傳原始資料）
outputs/

# Excel / 資料檔
*.xlsx
*.xls
*.csv

# 日誌
*.log

# 系統
.DS_Store
Thumbs.db

# VS Code / Cursor
.vscode/
.cursor/

# GitHub PAT（僅本機／工作排程器用，勿提交）
scripts/.github_pat_local
scripts/trigger_dispatch.log
